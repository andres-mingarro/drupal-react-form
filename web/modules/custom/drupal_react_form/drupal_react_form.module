<?php

declare(strict_types=1);

use Drupal\Core\Routing\RouteMatchInterface;

/**
 * Implements hook_help().
 */
function drupal_react_form_help(string $route_name, RouteMatchInterface $route_match): string {
  if ($route_name === 'help.page.drupal_react_form') {
    return '<p>' . t('Exposes Drupal Form API as JSON endpoints for React rendering. Add <code>data-react-form data-form-id="YourFormClass"</code> to any HTML element to mount a React form.') . '</p>';
  }
  return '';
}
